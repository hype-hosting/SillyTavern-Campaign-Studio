{
    "id": "vigil-falls",
    "name": "Vigil Falls",
    "version": "1.0.0",
    "description": "Gothic estate campaign tracking for the Vigil Falls worldbuild. Tracks inventory, world state, and Order faction standings.",
    "author": "hype-hosting",
    "marker": {
        "type": "details-summary",
        "prefix": "❖"
    },
    "sections": [
        {
            "id": "items",
            "match": "Items",
            "matchMode": "endsWith",
            "type": "inventory",
            "icon": "backpack",
            "parse": {
                "format": "markdown-list",
                "tagPattern": "\\(([^)]+)\\)"
            }
        },
        {
            "id": "world",
            "match": "World",
            "matchMode": "exact",
            "type": "key-value",
            "icon": "globe",
            "parse": {
                "format": "key-value",
                "separator": ":"
            },
            "fields": {
                "Weather": { "renderer": "text-atmosphere" },
                "Intent": { "renderer": "text" },
                "Path": { "renderer": "breadcrumb", "separator": "→" },
                "Characters": { "renderer": "character-pills", "separator": "," },
                "Vigil Falls's Diary": { "renderer": "quote-block" },
                "Affinity Level": { "renderer": "numeric-badge" },
                "Affinity Notes": { "renderer": "text" }
            }
        },
        {
            "id": "orders",
            "match": "Order Standing",
            "matchMode": "exact",
            "type": "numeric-bars",
            "icon": "shield",
            "parse": {
                "format": "key-value-numeric",
                "separator": ":",
                "range": [-1.0, 1.0]
            },
            "display": {
                "colorNegative": "#e05555",
                "colorNeutral": "#666666",
                "colorPositive": "#7c6bde",
                "showDelta": true
            }
        }
    ],
    "rules": [
        {
            "id": "tracking",
            "name": "State Tracking",
            "icon": "📜",
            "enabled": true,
            "content": "When game state changes (inventory, world state, faction standings), output the current state. Include only sections that actually changed in this turn."
        },
        {
            "id": "inventory",
            "name": "Inventory",
            "icon": "🎒",
            "enabled": true,
            "content": "Track items found, received, used, or lost throughout the estate. Use tags like (equipped), (key), (quest), (consumable). Always output the full current inventory, not just changes."
        },
        {
            "id": "factions",
            "name": "Order Standing",
            "icon": "🛡",
            "enabled": true,
            "content": "Track standing with the Orders of Vigil Falls. Shift values (-1.0 to 1.0) based on actions, discoveries, alliances, and betrayals within the estate grounds."
        }
    ],
    "injection": {
        "systemPrompt": "Track game state using <campaign_data> YAML blocks appended to every reply. Include only sections that changed.",
        "includeSchema": true,
        "includeCurrentState": true,
        "stateDepth": 1
    },
    "theme": {
        "accentColor": "#7c6bde",
        "ambientEffect": "candlelight"
    }
}
